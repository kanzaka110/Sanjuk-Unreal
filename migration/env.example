# =============================================================================
# env.local — 새 PC 환경 변수 설정
# 이 파일을 복사하여 env.local로 저장하고, 새 PC에 맞게 수정하세요.
#   cp env.example env.local
# =============================================================================

# 사용자 홈 디렉토리 (Windows Git Bash 형식)
# 예시: /c/Users/newuser  또는  /home/newuser (Linux)
USER_HOME="/c/Users/newuser"

# Sanjuk-Unreal 레포 루트 경로 (Windows 형식, 슬래시 사용)
# 예시: C:/dev/Sanjuk-Unreal  또는  /home/user/Sanjuk-Unreal
REPO_ROOT_PATH="C:/dev/Sanjuk-Unreal"

# UE5 프로젝트 루트 경로 (MonolithTest 등)
# 예시: C:/Users/newuser/OneDrive/문서/Unreal Projects/MonolithTest
UE_PROJECT_ROOT="C:/Users/newuser/OneDrive/문서/Unreal Projects/MonolithTest"

# (선택) Claude Code 프로젝트 키
# Claude Code가 자동 생성하는 프로젝트 식별자.
# 경로에서 파생됨: C:\dev\Sanjuk-Unreal → C--dev-Sanjuk-Unreal
# 정확한 값은 Claude Code 실행 후 ~/.claude/projects/ 아래 폴더명 확인.
# 비워두면 REPO_ROOT_PATH에서 자동 추정함.
CLAUDE_PROJECT_KEY=""
